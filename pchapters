<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Pokémon RPG</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --brand:#1a3a5c;--brand-mid:#2563a8;--brand-light:#e8f0fb;
  --accent:#e8a020;--accent-light:#fdf3dc;
  --bg:#f4f6fa;--surface:#fff;--surface2:#f0f3f8;
  --border:#dde3ee;--border2:#c8d0e0;
  --text:#1a1f2e;--muted:#6b7a99;
  --red:#c03030;--green:#1a7a1a;
  --r:10px;--font-title:'Cinzel',serif;--font-body:'Nunito',sans-serif;
}
html,body{min-height:100%;background:var(--bg);font-family:var(--font-body);color:var(--text)}

/* NAV */
.nav{display:flex;align-items:center;justify-content:space-between;padding:0 28px;height:58px;background:var(--brand);position:sticky;top:0;z-index:100}
.nav-logo{font-family:var(--font-title);font-size:16px;font-weight:700;color:#fff;letter-spacing:1px}
.nav-logo span{color:var(--accent)}
.nav-links{display:flex;gap:4px}
.nav-link{font-size:13px;font-weight:600;font-family:var(--font-body);padding:7px 18px;border-radius:20px;border:none;background:transparent;color:rgba(255,255,255,.7);cursor:pointer;transition:all .2s}
.nav-link:hover{background:rgba(255,255,255,.12);color:#fff}
.nav-link.active{background:rgba(255,255,255,.18);color:#fff}
.nav-login{font-size:12px;font-weight:700;font-family:var(--font-body);padding:7px 18px;border-radius:20px;border:1.5px solid rgba(255,255,255,.5);background:transparent;color:#fff;cursor:pointer;transition:all .2s}
.nav-login:hover{background:var(--accent);border-color:var(--accent)}
.nav-login.active{background:var(--accent);border-color:var(--accent)}

/* PAGES */
.page{display:none;padding:28px;max-width:1000px;margin:0 auto}
.page.active{display:block}

/* FORM */
.field{display:flex;flex-direction:column;gap:5px;margin-bottom:12px}
.field label{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.6px}
.field input,.field select,.field textarea{padding:9px 12px;border-radius:8px;border:1.5px solid var(--border);background:var(--surface);font-family:var(--font-body);font-size:14px;color:var(--text);transition:border .2s;width:100%}
.field input:focus,.field select:focus{outline:none;border-color:var(--brand-mid)}
.field input[type=color]{height:40px;padding:4px 8px;cursor:pointer}
.btn{padding:9px 18px;border-radius:8px;border:none;font-family:var(--font-body);font-size:13px;font-weight:700;cursor:pointer;transition:all .2s;display:inline-block}
.btn-primary{background:var(--brand-mid);color:#fff}
.btn-primary:hover{background:var(--brand)}
.btn-warn{background:#fff8e0;color:#7a5010;border:1px solid #e8d080}
.btn-warn:hover{background:#fdf0b0}
.btn-danger{background:#fde8e8;color:var(--red);border:1px solid #f0c0c0}
.btn-danger:hover{background:#f8c8c8}
.btn-sm{padding:5px 11px;font-size:12px}
.btn-full{width:100%}
.fb{font-size:12px;font-weight:700;text-align:center;padding:7px 10px;border-radius:6px;margin-top:8px;display:none}
.fb-ok{background:#e0f0e0;color:var(--green)}
.fb-err{background:#fde8e8;color:var(--red)}

/* ROLADOR */
.roller-header{text-align:center;margin-bottom:28px;padding-top:8px}
.roller-header h2{font-family:var(--font-title);font-size:22px;color:var(--brand);margin-bottom:6px}
.roller-header p{font-size:14px;color:var(--muted)}
.roller-controls{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:18px}
.ctrl-group{display:flex;flex-direction:column;gap:6px}
.ctrl-group label{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.6px}
.ctrl-group select,.ctrl-group input{padding:9px 12px;border-radius:var(--r);border:1.5px solid var(--border);background:var(--surface);font-family:var(--font-body);font-size:14px;color:var(--text);transition:border .2s;width:100%}
.ctrl-group select:focus,.ctrl-group input:focus{outline:none;border-color:var(--brand-mid)}
.badges-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:20px;padding:12px 16px;background:#fff;border-radius:var(--r);border:1.5px solid #e0e0e0}
.badges-label{font-size:12px;font-weight:700;color:var(--muted);white-space:nowrap}
.badge-btn{width:34px;height:34px;border-radius:50%;border:2px solid #d0d0d0;background:#f4f4f4;cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center;transition:all .15s;user-select:none;line-height:1}
.badge-btn.earned{background:#fff8e0;border-color:#e8a020}
.badges-info{font-size:12px;color:var(--muted);margin-left:auto;white-space:nowrap;font-weight:600}
.roll-btn{width:100%;padding:15px;background:var(--brand-mid);color:#fff;border:none;border-radius:var(--r);font-family:var(--font-title);font-size:16px;letter-spacing:1.5px;cursor:pointer;transition:all .2s;margin-bottom:24px}
.roll-btn:hover{background:var(--brand);transform:translateY(-1px);box-shadow:0 4px 16px rgba(37,99,168,.25)}
.results-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:24px}
.poke-card{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r);padding:16px 12px;text-align:center;transition:all .25s;animation:fadeUp .35s both}
.poke-card:hover{border-color:var(--brand-mid);transform:translateY(-2px);box-shadow:0 4px 14px rgba(37,99,168,.12)}
.poke-card-img{width:70px;height:70px;margin:0 auto 10px;background:var(--surface2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:26px;overflow:hidden}
.poke-card-img img{width:70px;height:70px;object-fit:contain;image-rendering:pixelated;image-rendering:crisp-edges}
.poke-card-name{font-family:var(--font-title);font-size:12px;font-weight:600;color:var(--text);margin-bottom:6px;line-height:1.3}
.poke-card-meta{margin-bottom:8px}
.poke-rarity{display:inline-block;font-size:10px;font-weight:700;padding:2px 9px;border-radius:10px;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px}
.rc{background:#e0f0e0;color:#1a6a1a}.ri{background:#dde8f8;color:#1a4a8a}.rr{background:#f0e8ff;color:#5a1a9a}.rrr{background:#fff0d8;color:#8a4a00}
.type-pill{display:inline-block;font-size:9px;font-weight:800;padding:2px 7px;border-radius:5px;text-transform:uppercase;letter-spacing:.3px;margin:1px}
.t-fire{background:#ff9b4a;color:#7a2a00}.t-water{background:#6ab8ff;color:#003a6a}.t-grass{background:#78d878;color:#1a5a1a}.t-normal{background:#c8c8a0;color:#4a4a2a}.t-electric{background:#ffe030;color:#5a4a00}.t-psychic{background:#ff8fb0;color:#6a0030}.t-steel{background:#aababb;color:#2a3a3a}.t-fairy{background:#ffaad8;color:#6a0050}.t-ghost{background:#9090c0;color:#1a1a4a}.t-dragon{background:#7060f0;color:#fff}.t-ice{background:#96d8d8;color:#1a4a4a}.t-fighting{background:#c03030;color:#fff}.t-rock{background:#b8a050;color:#3a2a00}.t-ground{background:#e0c060;color:#3a2a00}.t-poison{background:#a060c0;color:#fff}.t-bug{background:#a0c020;color:#2a3a00}.t-dark{background:#705040;color:#fff}.t-flying{background:#88aaee;color:#1a1a5a}
.gender-icon{font-size:13px;margin-left:3px}
.poke-lvl,.poke-hab{font-size:11px;color:var(--muted);margin-top:3px}

/* FICHÁRIO */
.ficha-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;padding-top:8px}
.ficha-header h2{font-family:var(--font-title);font-size:20px;color:var(--text);font-weight:700}
.search-bar{padding:9px 16px;border-radius:20px;border:1.5px solid var(--border);background:var(--surface);font-family:var(--font-body);font-size:13px;width:220px;color:var(--text);transition:border .2s}
.search-bar:focus{outline:none;border-color:var(--brand-mid)}
.player-section{margin-bottom:28px}
.player-section-header{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.player-section-name{font-family:var(--font-title);font-size:12px;color:var(--text);letter-spacing:.8px;text-transform:uppercase}
.player-pontos-box{display:flex;align-items:center;gap:5px;background:var(--surface);border:1.5px solid var(--border);border-radius:20px;padding:3px 12px}
.player-pontos-lbl{font-size:10px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.4px}
.player-pontos-val{font-size:13px;font-weight:700;color:var(--text)}
.fichas-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(175px,1fr));gap:10px}
.ficha-card{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r);overflow:hidden;transition:all .2s;padding:16px 14px;display:flex;flex-direction:row;align-items:center;gap:12px}
.ficha-card:hover{border-color:var(--brand-mid);transform:translateY(-2px);box-shadow:0 4px 14px rgba(37,99,168,.1)}
.ficha-card-avatar{width:46px;height:46px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;overflow:hidden}
.ficha-card-avatar img{width:51px;height:51px;object-fit:cover;border-radius:50%}
.ficha-name{font-family:var(--font-title);font-size:12px;color:var(--text);line-height:1.4;letter-spacing:.3px}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:999;display:flex;align-items:center;justify-content:center}
.modal-box{background:var(--surface);border-radius:var(--r);padding:28px;width:100%;max-width:440px;box-shadow:0 8px 40px rgba(0,0,0,.2);position:relative}
.modal-title{font-family:var(--font-title);font-size:16px;color:var(--brand);margin-bottom:18px}
.modal-close{position:absolute;top:14px;right:16px;background:none;border:none;font-size:20px;cursor:pointer;color:var(--muted);line-height:1}
/* ADM */
.adm-login-wrap{max-width:380px;margin:40px auto}
.adm-login-card{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r);padding:32px 28px}
.adm-login-icon{width:56px;height:56px;background:var(--brand-light);border-radius:50%;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;font-size:26px}
.adm-login-title{font-family:var(--font-title);font-size:18px;color:var(--brand);text-align:center;margin-bottom:4px}
.adm-login-sub{font-size:13px;color:var(--muted);text-align:center;margin-bottom:24px}
.adm-layout{display:grid;grid-template-columns:210px 1fr;gap:20px;padding-top:8px}
.adm-sidebar{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r);padding:16px;height:fit-content;position:sticky;top:78px}
.adm-sidebar-user{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid var(--border);word-break:break-all}
.adm-nav-btn{display:block;width:100%;text-align:left;padding:9px 12px;border-radius:8px;border:none;background:transparent;font-family:var(--font-body);font-size:13px;font-weight:600;color:var(--text);cursor:pointer;transition:all .15s;margin-bottom:3px}
.adm-nav-btn:hover{background:var(--brand-light);color:var(--brand-mid)}
.adm-nav-btn.active{background:var(--brand-light);color:var(--brand-mid)}
.adm-nav-sep{height:1px;background:var(--border);margin:8px 0}
.adm-nav-danger{color:var(--red) !important}
.adm-nav-danger:hover{background:#fde8e8 !important}
.adm-content{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r);padding:24px;min-height:500px}
.adm-section{display:none}
.adm-section.active{display:block}
.sec-title{font-family:var(--font-title);font-size:16px;color:var(--brand);margin-bottom:4px}
.sec-sub{font-size:13px;color:var(--muted);margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--border)}
.box{background:var(--surface2);border:1.5px solid var(--border);border-radius:8px;padding:16px;margin-bottom:20px}
.box-title{font-size:12px;font-weight:700;color:var(--brand-mid);margin-bottom:14px;text-transform:uppercase;letter-spacing:.4px}
.adm-table{width:100%;border-collapse:collapse;font-size:13px}
.adm-table th{text-align:left;font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;padding:8px 10px;border-bottom:1.5px solid var(--border)}
.adm-table td{padding:9px 10px;border-bottom:1px solid var(--border);vertical-align:middle}
.adm-table tr:last-child td{border-bottom:none}
.adm-table tr:hover td{background:var(--surface2)}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.tipos-wrap{display:flex;flex-wrap:wrap;gap:5px;margin-top:4px}
.tipo-tag{display:inline-flex;align-items:center;gap:3px;padding:3px 8px;border-radius:6px;font-size:11px;font-weight:700;background:var(--surface);border:1.5px solid var(--border);cursor:pointer;user-select:none;transition:all .15s}
.tipo-tag:hover{border-color:var(--brand-mid)}
.tipo-tag.sel{background:var(--brand-mid);color:#fff;border-color:var(--brand-mid)}

/* HISTÓRICO */
.hist-entry{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r);margin-bottom:12px;overflow:hidden}
.hist-header{padding:10px 14px;background:var(--surface2);border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.hist-body{padding:10px 14px;display:flex;gap:8px;flex-wrap:wrap}
.hist-poke{display:flex;align-items:center;gap:6px;padding:5px 8px;background:var(--surface);border-radius:6px;border:1px solid var(--border)}

@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
</style>
</head>
<body>

<nav class="nav">
  <div class="nav-logo">Pokémon<span>RPG</span></div>
  <div class="nav-links">
    <button class="nav-link active" onclick="goTo('roller',this)">Rolador</button>
    <button class="nav-link" onclick="goTo('ficha',this)">Fichário</button>
  </div>
  <button class="nav-login" id="btn-adm" onclick="goToAdm()">ADM</button>
</nav>

<!-- ═══════════ ROLADOR ═══════════ -->
<div class="page active" id="page-roller">
  <div class="roller-header">
    <h2>Rolador de Encontro</h2>
    <p>Selecione o bioma, configure seu personagem e role!</p>
  </div>
  <div class="roller-controls">
    <div class="ctrl-group"><label>Bioma</label><select id="bioma"></select></div>
    <div class="ctrl-group">
      <label>Personagem</label>
      <input type="text" id="personagem" placeholder="Nome do personagem..." list="personagens-lista"/>
      <datalist id="personagens-lista"></datalist>
    </div>
    <div class="ctrl-group"><label>Pokémon adicionais</label><input type="number" id="n-adicionais" value="0" min="0" max="10"/></div>
  </div>
  <div class="badges-row">
    <span class="badges-label">Provas de valor:</span>
    <button class="badge-btn earned" data-idx="0">⭐</button>
    <button class="badge-btn earned" data-idx="1">⭐</button>
    <button class="badge-btn" data-idx="2">☆</button>
    <button class="badge-btn" data-idx="3">☆</button>
    <button class="badge-btn" data-idx="4">☆</button>
    <button class="badge-btn" data-idx="5">☆</button>
    <button class="badge-btn" data-idx="6">☆</button>
    <button class="badge-btn" data-idx="7">☆</button>
    <span class="badges-info" id="badges-info">2 provas → Nível 11–30</span>
  </div>
  <button class="roll-btn" onclick="rolarEncontro()">⚔ Rolar Encontro</button>
  <div id="results-section"></div>
  <div id="historico-wrap" style="margin-top:32px;display:none">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
      <div style="font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.6px">Histórico de Rolagens</div>
      <div style="font-size:12px;color:var(--muted)" id="hist-page-label"></div>
    </div>
    <div id="historico-lista"></div>
    <div id="hist-paginacao" style="display:flex;justify-content:center;gap:10px;margin-top:16px">
      <button id="hist-prev" class="btn btn-sm" style="background:var(--surface);border:1.5px solid var(--border);color:var(--text)" onclick="mudarPaginaHist(-1)">← Mais recentes</button>
      <button id="hist-next" class="btn btn-sm" style="background:var(--surface);border:1.5px solid var(--border);color:var(--text)" onclick="mudarPaginaHist(1)">Mais antigas →</button>
    </div>
  </div>
</div>

<!-- ═══════════ FICHÁRIO ═══════════ -->
<div class="page" id="page-ficha">
  <div class="ficha-header">
    <h2>Fichário de Personagens</h2>
    <input class="search-bar" type="text" placeholder="Buscar personagem..." oninput="filtrarFichas(this.value)"/>
  </div>
  <div class="fichas-grid" id="fichas-grid"></div>
</div>

<!-- ═══════════ ADM ═══════════ -->
<div class="page" id="page-adm">

  <!-- LOGIN -->
  <div id="adm-login-wrap" class="adm-login-wrap">
    <div class="adm-login-card">
      <div class="adm-login-icon">🔐</div>
      <div class="adm-login-title">Área ADM</div>
      <div class="adm-login-sub">Acesso restrito aos administradores</div>
      <div class="field"><label>Usuário</label><input type="text" id="login-email" placeholder="usuário"/></div>
      <div class="field"><label>Senha</label><input type="password" id="login-senha" placeholder="••••••••" onkeydown="if(event.key==='Enter')fazerLogin()"/></div>
      <button class="btn btn-primary btn-full" style="margin-top:4px" onclick="fazerLogin()">Entrar</button>
      <div class="fb fb-err" id="login-erro">E-mail ou senha incorretos.</div>
    </div>
  </div>

  <!-- PAINEL -->
  <div id="adm-painel" style="display:none">
    <div class="adm-layout">
      <div class="adm-sidebar">
        <div class="adm-sidebar-user" id="adm-user-label">—</div>
        <button class="adm-nav-btn active" onclick="admTab('personagens',this)">👥 Personagens</button>
        <button class="adm-nav-btn" onclick="admTab('biomas',this)">🗺️ Biomas</button>
        <button class="adm-nav-btn" onclick="admTab('pokemons',this)">⚡ Pokémon</button>
        <div class="adm-nav-sep"></div>
        <button class="adm-nav-btn" onclick="admTab('admins',this)">🔑 Admins</button>
        <button class="adm-nav-btn" onclick="admTab('editor',this)">🎨 Editor Visual</button>
        <div class="adm-nav-sep"></div>
        <button class="adm-nav-btn adm-nav-danger" onclick="fazerLogout()">Sair</button>
      </div>
      <div class="adm-content">

        <!-- ── PERSONAGENS ── -->
        <div class="adm-section active" id="sec-personagens">
          <div class="sec-title">Personagens</div>
          <div class="sec-sub">Adicione, edite e remova personagens do fichário</div>
          <div class="box">
            <div class="box-title">Novo personagem</div>
            <div class="g2">
              <div class="field"><label>Nome do Player</label><input type="text" id="np-player" placeholder="Ex: Lucas"/></div>
              <div class="field"><label>Nome do Personagem</label><input type="text" id="np-nome" placeholder="Ex: Ash Ketchum"/></div>
              <div class="field"><label>Cor do avatar</label><input type="color" id="np-cor" value="#2563a8"/></div>
              <div class="field"><label>Imagem do personagem (avatar)</label>
                <input type="file" id="np-img" accept="image/*" onchange="previewPersonagemImg(this)" style="font-size:13px"/>
                <div style="margin-top:8px;display:flex;align-items:center;gap:10px">
                  <div id="np-img-preview" style="width:57px;height:57px;border-radius:50%;background:var(--surface2);border:2px solid var(--border);display:flex;align-items:center;justify-content:center;overflow:hidden"><img class="unown-fallback-img" src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/201.png" style="width:44px;height:44px;object-fit:contain;image-rendering:pixelated"/></div>
                  <span style="font-size:11px;color:var(--muted)">Pré-visualização</span>
                </div>
              </div>
            </div>
            <button class="btn btn-primary btn-sm" onclick="adicionarPersonagem()">+ Adicionar</button>
            <div class="fb fb-ok" id="np-fb">✓ Personagem adicionado!</div>
          </div>
          <div class="box" style="margin-top:4px">
            <div class="box-title">Pontos por Player</div>
            <table class="adm-table" id="players-pontos-table">
              <thead><tr><th>Player</th><th>Pontos</th><th>Ações</th></tr></thead>
              <tbody id="tbody-players"></tbody>
            </table>
          </div>
          <div class="box" style="margin-top:4px">
            <div class="box-title">Personagens cadastrados</div>
            <table class="adm-table">
              <thead><tr><th>Personagem</th><th>Player</th><th>Ações</th></tr></thead>
              <tbody id="tbody-personagens"></tbody>
            </table>
          </div>
        </div>

        <!-- ── BIOMAS ── -->
        <div class="adm-section" id="sec-biomas">
