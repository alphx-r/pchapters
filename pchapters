function fazerLogin(){
  const email=document.getElementById('login-email').value.trim();
  const senha=document.getElementById('login-senha').value;
  const found=admins.find(a=>a.email===email&&a.senha===senha);
  if(!found){fb('login-erro',3000);return;}
  admLogado=found;
  document.getElementById('adm-login-wrap').style.display='none';
  document.getElementById('adm-painel').style.display='block';
  document.getElementById('adm-user-label').textContent=email;
  renderTbodyPersonagens();
  renderTbodyPlayers();
}
function fazerLogout(){
  admLogado=null;
  document.getElementById('adm-login-wrap').style.display='block';
  document.getElementById('adm-painel').style.display='none';
  document.getElementById('login-email').value='';
  document.getElementById('login-senha').value='';
}

