const SPRITE_BASE='https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/';

// Mapa de nomes especiais que diferem do slug padrão da PokéAPI
const SLUG_MAP={
  'mr. mime':'mr-mime','mr.mime':'mr-mime','mime jr.':'mime-jr',
  'farfetch\'d':'farfetchd','sirfetch\'d':'sirfetchd',
  'flabébé':'flabebe','flab\u00e9b\u00e9':'flabebe',
  'squawkabilly':'squawkabilly','squawkabilly (blue)':'squawkabilly',
  'squawkabilly (blue plumage)':'squawkabilly',
  'nidoran♀':'nidoran-f','nidoran♂':'nidoran-m',
  'ho-oh':'ho-oh','porygon-z':'porygon-z','porygon2':'porygon2',
  'type: null':'type-null','jangmo-o':'jangmo-o','hakamo-o':'hakamo-o','kommo-o':'kommo-o',
};

function toSlug(name){
  const lower=name.toLowerCase().trim();
  if(SLUG_MAP[lower])return SLUG_MAP[lower];
  return lower
    .replace(/\s*\(.*?\)/g,'')
    .trim()
    .replace(/[^a-z0-9\-]/g,'')
    .replace(/\s+/g,'-');
}

async function fetchPokeAPI(url){
  const r=await fetch(url,{headers:{'Accept':'application/json'}});
  if(!r.ok)throw new Error(`HTTP ${r.status}`);
  return r.json();
}

async function importarDaPokeAPI(){
  const lista=document.getElementById('imp-lista').value.trim();
  const bioma=document.getElementById('imp-bioma').value;
  const raridade=document.getElementById('imp-raridade').value;
  if(!lista){alert('Cole ao menos um nome de Pokémon.');return;}
  const names=lista.split('\n').map(n=>n.trim()).filter(Boolean);
  if(names.length===0)return;

  const btn=document.getElementById('imp-btn');
  const progress=document.getElementById('imp-progress');
  const status=document.getElementById('imp-status');
  const bar=document.getElementById('imp-bar');
  const fbOk=document.getElementById('imp-fb-ok');
  const fbErr=document.getElementById('imp-fb-err');
  btn.disabled=true;progress.style.display='block';
  fbOk.style.display='none';fbErr.style.display='none';

  const erros=[];
  let ok=0;

  for(let i=0;i<names.length;i++){
    const raw=names[i];
    const slug=toSlug(raw);
    status.textContent=`Buscando ${raw}... (${i+1}/${names.length})`;
    bar.style.width=`${Math.round((i/names.length)*100)}%`;
    try{
      const data=await fetchPokeAPI(`https://pokeapi.co/api/v2/pokemon/${slug}`);
      const species=await fetchPokeAPI(data.species.url);

      // tipos
      const tipos=data.types.map(t=>t.type.name);

      // habilidade principal (não hidden)
      const habs=data.abilities
        .filter(a=>!a.is_hidden)
        .map(a=>a.ability.name.replace(/-/g,' ').replace(/\b\w/g,c=>c.toUpperCase()));
      const habilidade=habs[0]||'—';

      // sprite via PokeAPI sprites (pixel 32x32 clássico)
      const sprite=`${SPRITE_BASE}${data.id}.png`;

      // gênero
      const gr=species.gender_rate??-1;
      const genero=gr===-1?'genderless':gr===0?'macho':gr===8?'femea':'1d2';

      // evita duplicata no mesmo bioma
      const nomeFormatado=raw.trim();
      if(!pokemonDB.find(p=>p.nome.toLowerCase()===nomeFormatado.toLowerCase()&&p.bioma===bioma)){
        pokemonDB.push({id:uid(),nome:nomeFormatado,emoji:'❓',sprite,tipos,habilidade,raridade,genero,bioma});
      }
      ok++;
    }catch(e){
      console.warn(`Erro ao buscar "${raw}" (slug: "${slug}"):`,e.message);
      erros.push(raw);
    }
    await new Promise(r=>setTimeout(r,250));
  }

  save('rpg-pokemons',pokemonDB);
  bar.style.width='100%';
  btn.disabled=false;
  progress.style.display='none';

  if(erros.length>0){
    fbErr.textContent=`⚠ ${ok} importados. Não encontrados: ${erros.join(', ')}`;
    fbErr.style.display='block';
    setTimeout(()=>fbErr.style.display='none',8000);
  } else {
    fbOk.textContent=`✓ ${ok} Pokémon importados com sucesso!`;
    fbOk.style.display='block';
    setTimeout(()=>fbOk.style.display='none',3000);
  }
  document.getElementById('imp-lista').value='';
  renderTbodyPokemons();renderTbodyBiomas();
}

