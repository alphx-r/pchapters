const ESTILO_DEFAULT = {
  brand:'#1a3a5c', brandMid:'#2563a8', accent:'#e8a020',
  bg:'#f4f6fa', surface:'#ffffff', text:'#1a1f2e',
  fontTitle:"'Cinzel',serif", fontBody:"'Nunito',sans-serif",
  radius:'10px', customCss:''
};

function carregarEditorUI(){
  const e = load('rpg-estilo', ESTILO_DEFAULT);
  document.getElementById('ec-brand').value       = e.brand;
  document.getElementById('ec-brand-mid').value   = e.brandMid;
  document.getElementById('ec-accent').value      = e.accent;
  document.getElementById('ec-bg').value          = e.bg;
  document.getElementById('ec-surface').value     = e.surface;
  document.getElementById('ec-text').value        = e.text;
  document.getElementById('ec-font-title').value  = e.fontTitle;
  document.getElementById('ec-font-body').value   = e.fontBody;
  document.getElementById('ec-radius').value      = e.radius;
  document.getElementById('ec-custom-css').value  = e.customCss||'';
}

function aplicarEstilo(){
  const e = coletarEstilo();
  aplicarVars(e);
}

function coletarEstilo(){
  return {
    brand:     document.getElementById('ec-brand').value,
    brandMid:  document.getElementById('ec-brand-mid').value,
    accent:    document.getElementById('ec-accent').value,
    bg:        document.getElementById('ec-bg').value,
    surface:   document.getElementById('ec-surface').value,
    text:      document.getElementById('ec-text').value,
    fontTitle: document.getElementById('ec-font-title').value,
    fontBody:  document.getElementById('ec-font-body').value,
    radius:    document.getElementById('ec-radius').value,
    customCss: document.getElementById('ec-custom-css').value,
  };
}

function aplicarVars(e){
  const root = document.documentElement;
  // hex to rgb helper for brand-light derivation
  root.style.setProperty('--brand',       e.brand);
  root.style.setProperty('--brand-mid',   e.brandMid);
  root.style.setProperty('--accent',      e.accent);
  root.style.setProperty('--bg',          e.bg);
  root.style.setProperty('--surface',     e.surface);
  root.style.setProperty('--text',        e.text);
  root.style.setProperty('--font-title',  e.fontTitle);
  root.style.setProperty('--font-body',   e.fontBody);
  root.style.setProperty('--r',           e.radius);
  // custom CSS injection
  let tag = document.getElementById('custom-css-tag');
  if(!tag){tag=document.createElement('style');tag.id='custom-css-tag';document.head.appendChild(tag);}
  tag.textContent = e.customCss||'';
  // load Google Fonts if needed
  injectFonts(e.fontTitle+' '+e.fontBody);
}

function injectFonts(str){
  const needed=[];
  if(str.includes('Playfair'))  needed.push('Playfair+Display:wght@400;600;700');
  if(str.includes('Oswald'))    needed.push('Oswald:wght@400;600;700');
  if(str.includes('Raleway'))   needed.push('Raleway:wght@400;600;700');
  if(str.includes('Press Start')) needed.push('Press+Start+2P');
  if(str.includes('Fredoka'))   needed.push('Fredoka+One');
  if(str.includes('Poppins'))   needed.push('Poppins:wght@400;500;600;700');
  if(str.includes('Inter'))     needed.push('Inter:wght@400;500;600;700');
  if(str.includes('Roboto'))    needed.push('Roboto:wght@400;500;700');
  if(str.includes('Lato'))      needed.push('Lato:wght@400;700');
  if(str.includes('Open Sans')) needed.push('Open+Sans:wght@400;600;700');
  needed.forEach(f=>{
    const id='gf-'+f.split(':')[0].replace(/\+/g,'-');
    if(!document.getElementById(id)){
      const l=document.createElement('link');
      l.id=id;l.rel='stylesheet';
      l.href=`https://fonts.googleapis.com/css2?family=${f}&display=swap`;
      document.head.appendChild(l);
    }
  });
}

function salvarEstilo(){
  const e=coletarEstilo();
  save('rpg-estilo',e);
  aplicarVars(e);
  fb('editor-fb-ok');
}

function resetarEstilo(){
  if(!confirm('Restaurar todas as configurações visuais para o padrão?'))return;
  save('rpg-estilo',ESTILO_DEFAULT);
  carregarEditorUI();
  aplicarVars(ESTILO_DEFAULT);
}

function aplicarEstiloSalvo(){
  const e=load('rpg-estilo',ESTILO_DEFAULT);
  aplicarVars(e);
}

