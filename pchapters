// ROLADOR
// ══════════════════════════════════════
function rollRarity(){
  const r=Math.ceil(Math.random()*100);
  if(r<=7)return 'rarissimo';if(r<=20)return 'raro';if(r<=60)return 'incomum';return 'comum';
}
function rollGender(g){
  if(g==='macho')return{s:'♂',c:'#3a80e0'};
  if(g==='femea')return{s:'♀',c:'#e04090'};
  if(g==='genderless')return{s:'—',c:'#888'};
  return Math.random()<.5?{s:'♂',c:'#3a80e0'}:{s:'♀',c:'#e04090'};
}
function rollLevel(){
  const c=document.querySelectorAll('.badge-btn.earned').length;
  const min=c===0?1:c*10+1, max=c===0?10:Math.min(c*10+10,90);
  return Math.floor(Math.random()*(max-min+1))+min;
}
function buildCardData(){
  const bioma=document.getElementById('bioma').value;
  const rarity=rollRarity();
  const pool=pokemonDB.filter(p=>p.bioma===bioma&&p.raridade===rarity);
  const fallback=pokemonDB.filter(p=>p.bioma===bioma);
  const p=pool.length>0?pool[Math.floor(Math.random()*pool.length)]
         :fallback.length>0?fallback[Math.floor(Math.random()*fallback.length)]
         :{nome:'???',emoji:'❓',tipos:['normal'],habilidade:'???',raridade:rarity,genero:'1d2'};
  const gender=rollGender(p.genero);
  return{nome:p.nome,tipos:p.tipos,emoji:p.emoji||'❓',sprite:p.sprite||null,habilidade:p.habilidade,rarity,genderS:gender.s,genderC:gender.c,lvl:rollLevel()};
}
const FALLBACK_SPRITE_DEFAULT = 'https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/201.png';
let FALLBACK_SPRITE = FALLBACK_SPRITE_DEFAULT;
let FALLBACK_AVATAR = FALLBACK_SPRITE_DEFAULT;

// Busca o sprite correto do Unown ? na API em runtime
fetch('https://pokeapi.co/api/v2/pokemon-form/10027/')
  .then(r=>r.json())
  .then(data=>{
    const url = data?.sprites?.front_default;
    if(url){
      FALLBACK_SPRITE = url;
      FALLBACK_AVATAR = url;
      // atualiza previews estáticos no HTML
      document.querySelectorAll('.unown-fallback-img').forEach(img=>img.src=url);
    }
  })
  .catch(()=>{});

function spriteHtml(pk){
  const src = pk.sprite || FALLBACK_SPRITE;
  return `<img src="${src}" alt="${pk.nome}" style="width:70px;height:70px;object-fit:contain;image-rendering:pixelated;image-rendering:crisp-edges" onerror="this.src='${FALLBACK_SPRITE}'"/>`;
}
function buildCardHtml(pk,delay){
  const pills=pk.tipos.map(t=>`<span class="type-pill ${tcls[t]||'t-normal'}">${t}</span>`).join('');
  return`<div class="poke-card" style="animation-delay:${delay}s">
    <div class="poke-card-img">${spriteHtml(pk)}</div>
    <div class="poke-card-name">${pk.nome} <span class="gender-icon" style="color:${pk.genderC}">${pk.genderS}</span></div>
    <div class="poke-card-meta">${pills}</div>
    <div><span class="poke-rarity ${rcls[pk.rarity]}">${rlbl[pk.rarity]}</span></div>
    <div class="poke-lvl">Nível ${pk.lvl}</div>
    <div class="poke-hab">Hab: ${pk.habilidade}</div>
  </div>`;
}
function rolarEncontro(){
  const adicionais=Math.max(0,parseInt(document.getElementById('n-adicionais').value)||0);
  const total=3+adicionais;
  const bioma=document.getElementById('bioma').value;
  const personagem=document.getElementById('personagem').value||'—';
  const section=document.getElementById('results-section');
  section.innerHTML='';
  const pokes=[];
  const grid=document.createElement('div');
  grid.className='results-grid';
  grid.style.gridTemplateColumns=`repeat(${Math.min(total<=4?total:3,total)},1fr)`;
  for(let i=0;i<total;i++){const pk=buildCardData();pokes.push(pk);grid.innerHTML+=buildCardHtml(pk,i*0.08);}
  section.appendChild(grid);
  salvarNoHistorico(bioma,personagem,pokes);
}

