const badgeBtns = [...document.querySelectorAll('.badge-btn')];
badgeBtns.forEach(btn=>{
  btn.addEventListener('click',function(){
    const idx = parseInt(this.dataset.idx);
    const currentEarned = badgeBtns.filter(b=>b.classList.contains('earned')).length;
    // Se clicou na última estrela earned (desmarcar tudo a partir dali)
    // Se já está earned e é a última, desmarca ela e as seguintes
    // Lógica: clicar em idx X marca 0..X; se X já é o último earned, desmarca X
    if(this.classList.contains('earned') && currentEarned === idx+1){
      // desmarca essa
      badgeBtns.forEach((b,i)=>{
        if(i>=idx){ b.classList.remove('earned'); b.textContent='☆'; }
      });
    } else {
      // marca todas de 0 até idx
      badgeBtns.forEach((b,i)=>{
        if(i<=idx){ b.classList.add('earned'); b.textContent='⭐'; }
        else       { b.classList.remove('earned'); b.textContent='☆'; }
      });
    }
    atualizarBadgeInfo();
  });
});
function atualizarBadgeInfo(){
  const c=document.querySelectorAll('.badge-btn.earned').length;
  const min=c===0?1:c*10+1, max=c===0?10:Math.min(c*10+10,90);
  document.getElementById('badges-info').textContent=`${c} prova${c!==1?'s':''} → Nível ${min}–${max}`;
}

