function load(k,d){try{const v=localStorage.getItem(k);return v!=null?JSON.parse(v):d;}catch(e){return d;}}
function save(k,v){
  try{
    localStorage.setItem(k,JSON.stringify(v));
  }catch(e){
    if(e.name==='QuotaExceededError'||e.code===22){
      alert('⚠️ Armazenamento local cheio!\n\nIsso pode acontecer por excesso de imagens salvas em base64.\n\nSugestão: remova alguns personagens ou Pokémon com imagem, ou migre para o Supabase para armazenamento ilimitado.');
    }
  }
}

