// HISTÓRICO
// ══════════════════════════════════════
function salvarNoHistorico(bioma,personagem,pokes){
  const agora=new Date();
  historico.unshift({
    bioma,personagem,pokes,
    hora:agora.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit',second:'2-digit'}),
    data:agora.toLocaleDateString('pt-BR')
  });
  save('rpg-historico',historico);
  histPagina = 0;
  renderHistorico();
}
let histPagina = 0;
const HIST_POR_PAG = 10;

function mudarPaginaHist(dir){
  const totalPags = Math.ceil(historico.length / HIST_POR_PAG);
  histPagina = Math.max(0, Math.min(histPagina + dir, totalPags - 1));
  renderHistorico();
}
function renderHistorico(){
  const wrap  = document.getElementById('historico-wrap');
  const lista = document.getElementById('historico-lista');
  if(historico.length===0){wrap.style.display='none';return;}
  wrap.style.display='block';

  const totalPags = Math.ceil(historico.length / HIST_POR_PAG);
  histPagina = Math.max(0, Math.min(histPagina, totalPags - 1));
  const inicio = histPagina * HIST_POR_PAG;
  const pagina = historico.slice(inicio, inicio + HIST_POR_PAG);

  // label
  document.getElementById('hist-page-label').textContent =
    `Página ${histPagina+1} de ${totalPags} · ${historico.length} rolagem${historico.length!==1?'s':''}`;

  // botões
  document.getElementById('hist-prev').style.display = histPagina > 0 ? '' : 'none';
  document.getElementById('hist-next').style.display = histPagina < totalPags-1 ? '' : 'none';
  document.getElementById('hist-paginacao').style.display = totalPags > 1 ? 'flex' : 'none';

  lista.innerHTML = pagina.map(e=>{
    const ph=e.pokes.map(pk=>`
      <div class="hist-poke">
        <div style="width:36px;height:36px;display:flex;align-items:center;justify-content:center;background:var(--surface2);border-radius:50%;overflow:hidden;flex-shrink:0">
          ${pk.sprite
            ? `<img src="${pk.sprite}" style="width:44px;height:44px;object-fit:contain;image-rendering:pixelated" onerror="this.src='${FALLBACK_SPRITE}'"/>`
            : `<img src="${FALLBACK_SPRITE}" style="width:44px;height:44px;object-fit:contain;image-rendering:pixelated"/>`}
        </div>
        <div>
          <div style="font-size:11px;font-weight:600;color:var(--text)">${pk.nome} <span style="color:${pk.genderC}">${pk.genderS}</span></div>
          <div style="font-size:10px;color:var(--muted)">Nv.${pk.lvl} · <span class="poke-rarity ${rcls[pk.rarity]}" style="padding:1px 5px;font-size:9px">${rlbl[pk.rarity]}</span></div>
        </div>
      </div>`).join('');
    return`<div class="hist-entry">
      <div class="hist-header">
        <div><span style="font-size:12px;font-weight:700;color:var(--brand)">${e.personagem}</span><span style="font-size:11px;color:var(--muted);margin-left:8px">• ${e.bioma}</span></div>
        <span style="font-size:11px;color:var(--muted)">${e.hora} · ${e.data}</span>
      </div>
      <div class="hist-body">${ph}</div>
    </div>`;
  }).join('');
}

